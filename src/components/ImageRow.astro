---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';

interface ImageItem {
	src: ImageMetadata | string;
	alt: string;
}

interface Props {
	group?: string;
	images: ImageItem[];
}

const { group, images } = Astro.props;
const imageCount = Math.max(images.length, 1);

const assetModules = import.meta.glob('../assets/application/**/*.{png,PNG,jpg,JPG,jpeg,JPEG,webp,WEBP,avif,AVIF}', {
	eager: true,
	import: 'default',
}) as Record<string, ImageMetadata>;

function resolveImage(src: ImageMetadata | string) {
	if (typeof src !== 'string') return src;

	const assetPath = group
		? `../assets/application/${group}/${src}`
		: `../assets/application/${src}`;

	const image = assetModules[assetPath];

	if (!image) {
		throw new Error(`ImageRow could not find local image: ${assetPath}`);
	}

	return image;
}
---

<div class="image-row" style={`--image-count: ${imageCount};`}>
	{images.map((image) => (
		<figure class="image-card">
			<Image
				src={resolveImage(image.src)}
				alt={image.alt}
				loading="lazy"
				sizes={`${Math.max(Math.floor(100 / imageCount), 1)}vw`}
			/>
		</figure>
	))}
</div>

<style>
	.image-row {
		display: grid;
		grid-template-columns: repeat(var(--image-count), minmax(0, 1fr));
		gap: 0.75rem;
		margin: 1rem 0 1.5rem;
	}

	.image-card {
		margin: 0;
	}

	.image-card img {
		display: block;
		width: 100%;
		height: auto;
	}
</style>
